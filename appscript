      sh("Paiements").appendRow([uid("pay"),"CREDIT",clientId,today(),heure(),montant,"Crédit manuel",staffN,note||"Crédit solde",now()]);
      return json({ok:true,newSolde:newSolde});
    }
  }
  return json({ok:false,error:"Client non trouvé"});
}

