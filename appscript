            cs.getRange(ci+1,15).setValue(ts);
            break;
          }
        }
      }
    }
    if(f.clientId) updateClientVisite(f.clientId);
    var newStatut=recalcStatut(id);
    updateFacture({id:id,statut:newStatut});
    if(requestId) saveRequestLog(requestId,"createFacture",id);
    return json({ok:true,id:id,statut:newStatut});
  } finally {
    lock.releaseLock();
  }
}

function updateFacture(body){
  if(!body.id) return json({ok:false,error:"ID requis"});
  var s=sh("Factures"); var data=s.getDataRange().getValues(); var ts=now();
  for(var i=1;i<data.length;i++){
    if(data[i][0]===body.id){
      if(body.statut!==undefined) s.getRange(i+1,5).setValue(body.statut);
      if(body.notes!==undefined) s.getRange(i+1,6).setValue(body.notes);
      if(body.echeance!==undefined) s.getRange(i+1,4).setValue(body.echeance);
      s.getRange(i+1,9).setValue(ts);
      return json({ok:true});
    }
  }
  return json({ok:false,error:"Facture non trouvée"});
}
function addPaiement(body){
  var p=body.paiement; if(!p||!p.factureId) return json({ok:false,error:"Données manquantes"});
  var facture=findFactureRow(p.factureId);
  if(!facture) return json({ok:false,error:"Facture non trouvée"});
  var factureClientId=String(facture.row[1]||"").trim();
  if(!p.clientId && factureClientId) p.clientId=factureClientId;
  if(p.clientId && !clientExists(p.clientId)) return json({ok:false,error:"Client non trouvé"});
  var requestId = normalizeReqId((body&&body.requestId) || (p&&p.requestId));
  var lock=lockScript();
  try {
    if(requestId){
      var existingReq=findRequestLog(requestId);
      if(existingReq){
        var st=existingReq.resourceId?recalcStatut(existingReq.resourceId):recalcStatut(p.factureId);
        return json({ok:true,statut:st,duplicate:true});
      }
    }
    var ts=now();
    sh("Paiements").appendRow([uid("pay"),p.factureId,p.clientId||"",p.date||today(),p.heure||heure(),
      num(p.montant),p.mode||"CB",p.staff||"",p.note||"",ts]);
    var newStatut=recalcStatut(p.factureId);
    updateFacture({id:p.factureId,statut:newStatut});
    if(requestId) saveRequestLog(requestId,"addPaiement",p.factureId);
    return json({ok:true,statut:newStatut});
  } finally {
    lock.releaseLock();
  }
}

function recalcStatut(factureId){
  var lData=sh("Lignes").getDataRange().getValues();
  var pData=sh("Paiements").getDataRange().getValues();
  var totals=factureTotalsFromData(factureId,lData,pData);
  var reste=totals.reste;
  var paye=totals.paye;
  if(reste<=0) return "payée";
  if(paye>0)   return "partiellement payée";
  return "impayée";
}
function createAvoir(body){
  var factureId=body.factureId; var staffN=body.staff||""; var notes=body.notes||"";
  var montantAvoir=num(body.montant);
  if(!factureId) return json({ok:false,error:"factureId requis"});
  if(!(montantAvoir>0)) return json({ok:false,error:"Montant d'avoir invalide"});
  var requestId = normalizeReqId(body&&body.requestId);
  var lock=lockScript();
  try {
    if(requestId){
      var existingReq=findRequestLog(requestId);
      if(existingReq&&existingReq.resourceId){
        return json({ok:true,avoirId:existingReq.resourceId,duplicate:true});
      }
    }
  var fData=sh("Factures").getDataRange().getValues();
  var lData=sh("Lignes").getDataRange().getValues();
  var pData=sh("Paiements").getDataRange().getValues();
  var origF=null;
  for(var i=1;i<fData.length;i++){ if(fData[i][0]===factureId){origF=fData[i];break;} }
  if(!origF) return json({ok:false,error:"Facture non trouvée"});

  var statutOrig=String(origF[4]||"").toLowerCase();
  if(statutOrig==="avoir"||statutOrig==="annulée") return json({ok:false,error:"Cette facture ne peut pas recevoir d'avoir"});

  var totals=factureTotalsFromData(factureId,lData,pData);
  if(totals.reste<=0) return json({ok:false,error:"La facture est déjà soldée"});
  var alloc=allocationAvoir(montantAvoir,totals.reste);
  if(!(alloc.applique>0)) return json({ok:false,error:"Aucun montant à appliquer sur la facture"});

  var avoirId=genFactureId(); var ts=now();
  var noteAvoir="Avoir de "+factureId+" | montant="+alloc.montant.toFixed(2)+" | appliqué="+alloc.applique.toFixed(2)+" | surplus="+alloc.surplus.toFixed(2);
  if(notes) noteAvoir+=" | note="+notes;
  sh("Factures").appendRow([avoirId,origF[1],today(),today(),"avoir",noteAvoir,staffN,ts,ts,"NON"]);
  sh("Lignes").appendRow([uid("lig"),avoirId,"Avoir lié à "+factureId,"📋",1,-alloc.montant,-alloc.montant,0,0,0,""]);

  var notePaiement="Avoir "+avoirId+" appliqué à la facture"+(notes?" — "+notes:"");
  sh("Paiements").appendRow([uid("pay"),factureId,origF[1]||"",today(),heure(),alloc.applique,"Avoir",staffN,notePaiement,ts]);
  var newStatut=recalcStatut(factureId);
  var newNotes=(origF[5]?String(origF[5])+"\n":"")+"Avoir appliqué: "+avoirId+" ("+alloc.applique.toFixed(2)+"€"+(alloc.surplus>0?", surplus crédité: "+alloc.surplus.toFixed(2)+"€":"")+")";
  updateFacture({id:factureId,statut:newStatut,notes:newNotes});

  var newSolde=null;
  if(alloc.surplus>0 && origF[1]){
    newSolde=updateClientSoldeByDelta(origF[1],alloc.surplus,ts);
    sh("Paiements").appendRow([uid("pay"),"CREDIT",origF[1],today(),heure(),alloc.surplus,"Avoir",staffN,"Surplus avoir "+avoirId+" (facture "+factureId+")",ts]);
  }

  if(requestId) saveRequestLog(requestId,"createAvoir",avoirId);
  return json({ok:true,avoirId:avoirId,applique:alloc.applique,surplus:alloc.surplus,newStatut:newStatut,newSolde:newSolde});
  } finally {
    lock.releaseLock();
  }
}

