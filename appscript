function getStats(){
  var tod=today(); var mois=tod.slice(0,7);
  var pData=sh("Paiements").getDataRange().getValues();
  var caJour=0,caMois=0,caTotal=0;
  for(var i=1;i<pData.length;i++){
    var m=num(pData[i][5]); var d=String(pData[i][3]||"").slice(0,10);
    caTotal+=m; if(d===tod)caJour+=m; if(d.slice(0,7)===mois)caMois+=m;
  }
  var fData=sh("Factures").getDataRange().getValues();
  var nbRetard=0,impaye=0;
  for(var j=1;j<fData.length;j++){
    var st=fData[j][4];
    if(st!=="payée"&&st!=="avoir"&&st!=="annulée") nbRetard++;
  }
  return json({ok:true,stats:{caJour:Math.round(caJour*100)/100,caMois:Math.round(caMois*100)/100,
    caTotal:Math.round(caTotal*100)/100,nbRetard:nbRetard,
    nbFactures:Math.max(0,fData.length-1),nbClients:Math.max(0,sh("Clients").getLastRow()-1)}});
}

// HELPERS INTERNES
function updateClientVisite(clientId){
  var s=sh("Clients"); var data=s.getDataRange().getValues();
  for(var i=1;i<data.length;i++){
    if(data[i][0]===clientId){ s.getRange(i+1,13).setValue(today()); s.getRange(i+1,15).setValue(now()); break; }
  }
}
function updateClientSoldeCompte(clientId,paiements){
  var compte=0;
  (paiements||[]).forEach(function(p){ if(p.mode==="Compte") compte+=num(p.montant); });
  if(!compte) return;
  var s=sh("Clients"); var data=s.getDataRange().getValues();
  for(var i=1;i<data.length;i++){
    if(data[i][0]===clientId){ s.getRange(i+1,7).setValue(num(data[i][6])-compte); break; }
  }
}
