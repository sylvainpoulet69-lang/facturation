function doGet(e) {
  var action = String((e && e.parameter && e.parameter.action) || "").trim();
  if (action === "health") {
    return json({ ok: true, service: "FacturePro v2", ts: Date.now(), sheet: !!SS_ID });
  }
  return json({ ok: true, service: "FacturePro v2", ts: Date.now() });
}

function doPost(e) {
  try {
    var body = JSON.parse((e && e.postData && e.postData.contents) || "{}");
    var action = String(body.action || "").trim();

    // staffLogin n'a pas besoin de secret
    if (action !== "staffLogin" && body.secret !== APP_SECRET) {
      return json({ ok: false, error: "Non autorisé" });
    }

    switch (action) {
      case "staffLogin":      return staffLogin(body);
      case "listStaff":       return listStaff();
      case "listClients":     return listClients();
      case "upsertClient":    return upsertClient(body.client);
      case "listProduits":    return listProduits();
      case "upsertProduit":   return upsertProduit(body.produit);
      case "deleteProduit":   return deleteProduit(body.id);
      case "deleteProduct":   return deleteProduit(body.id); // compat ancienne action front
      case "listFactures":    return listFactures(body);
      case "createFacture":   return createFacture(body);
      case "updateFacture":   return updateFacture(body);
      case "addPaiement":     return addPaiement(body);
      case "createAvoir":     return createAvoir(body);
      case "createCreditNote": return createAvoir(body); // compat éventuelle front
      case "creditSolde":     return creditSolde(body);
      case "sendRelance":     return sendRelance(body);
      case "sendEmail":       return sendEmail(body);
      case "getConfig":       return getConfig();
      case "saveConfig":      return saveConfig(body.config);
      case "getStats":        return getStats();
      default:
        return json({ ok: false, error: "Action inconnue: " + action });
    }
  } catch (err) {
    return json({ ok: false, error: err.toString() });
  }
}

