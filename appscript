function rowToClient(r){
  return {
    id:r[0]||"",prenom:r[1]||"",nom:r[2]||"",tel:r[3]||"",email:r[4]||"",
    ville:r[5]||"",solde:num(r[6]),certif:bool(r[7]),cgv:bool(r[8]),
    licence:r[9]||"",tags:(r[10]?String(r[10]).split(",").map(function(t){return t.trim();}).filter(Boolean):[]),
    notes:r[11]||"",derniereVisite:r[12]||"",createdAt:r[13]||"",updatedAt:r[14]||""
  };
}
function clientRow(c,id,createdAt,updatedAt){
  return [id,c.prenom||"",c.nom||"",c.tel||"",c.email||"",c.ville||"",
    num(c.solde||0),c.certif?"OUI":"NON",c.cgv?"OUI":"NON",
    c.licence||"",Array.isArray(c.tags)?c.tags.join(","):(c.tags||""),
    c.notes||"",c.derniereVisite||today(),createdAt,updatedAt];
}
function upsertClient(c) {
  if(!c) return json({ok:false,error:"Données manquantes"});
  // Validation doublons téléphone/email
  var s=sh("Clients"); var data=s.getDataRange().getValues(); var ts=now();
  var telNorm=String(c.tel||"").replace(/\s+/g,"").trim();
  var emailNorm=String(c.email||"").trim().toLowerCase();
  var prenomNorm=String(c.prenom||"").trim().toLowerCase();
  var nomNorm=String(c.nom||"").trim().toLowerCase();
  for(var i=1;i<data.length;i++){
    var rowId=String(data[i][0]||"").trim();
    var rowTel=String(data[i][3]||"").replace(/\s+/g,"").trim();
    var rowEmail=String(data[i][4]||"").trim().toLowerCase();
    var rowPrenom=String(data[i][1]||"").trim().toLowerCase();
    var rowNom=String(data[i][2]||"").trim().toLowerCase();
    var isOther = !c.id || rowId !== c.id;
    if (isOther && telNorm && rowTel === telNorm && prenomNorm===rowPrenom && nomNorm===rowNom) {
      return json({ok:false,error:"Ce client existe déjà dans la base."});
    }
    if (isOther && telNorm && rowTel === telNorm) {
      return json({ok:false,error:"Téléphone déjà utilisé par "+data[i][1]+" "+data[i][2]});
    }
    if (isOther && emailNorm && rowEmail && rowEmail === emailNorm) {
      return json({ok:false,error:"Email déjà utilisé par "+data[i][1]+" "+data[i][2]});
    }
    if(c.id&&data[i][0]===c.id){
      // UPDATE
      c.tel = telNorm;
      c.email = emailNorm;
      var row=clientRow(c,data[i][0],data[i][13]||ts,ts);
      s.getRange(i+1,1,1,row.length).setValues([row]);
      return json({ok:true,action:"updated",client:rowToClient(row)});
    }
  }
  // INSERT
  if(!c.prenom||!c.nom||!telNorm) return json({ok:false,error:"Prénom, nom et téléphone requis"});
  c.tel = telNorm;
  c.email = emailNorm;
  var newId=uid("cli");
  var newRow=clientRow(c,newId,ts,ts);
  s.appendRow(newRow);
  return json({ok:true,action:"created",client:rowToClient(newRow)});
}
function creditSolde(body) {
  var clientId=body.clientId; var montant=num(body.montant); var note=body.note||""; var staffN=body.staff||"";
  if(!clientId||!montant) return json({ok:false,error:"clientId et montant requis"});
  var s=sh("Clients"); var data=s.getDataRange().getValues();
  for(var i=1;i<data.length;i++){
    if(data[i][0]===clientId){
      var newSolde=updateClientSoldeByDelta(clientId,montant,now());
