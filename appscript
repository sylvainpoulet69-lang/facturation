function sendRelance(body){
  var factureId=body.factureId; var staffN=body.staff||"";
  var relanceType=String(body.relanceType||"").trim().toLowerCase();
  if(!factureId) return json({ok:false,error:"factureId requis"});
  // Chercher facture + client
  var fData=sh("Factures").getDataRange().getValues();
  var lData=sh("Lignes").getDataRange().getValues();
  var pData=sh("Paiements").getDataRange().getValues();
  var cData=sh("Clients").getDataRange().getValues();
  var origF=null;
  for(var i=1;i<fData.length;i++){ if(fData[i][0]===factureId){origF=fData[i];break;} }
  if(!origF) return json({ok:false,error:"Facture non trouvée"});
  var clientId=origF[1];
  var client=null;
  for(var j=1;j<cData.length;j++){ if(cData[j][0]===clientId){client=cData[j];break;} }
  if(!client||!client[4]) return json({ok:false,error:"Email client manquant"});
  // Calculer reste
  var total=0;
  for(var k=1;k<lData.length;k++){
    if(lData[k][1]!==factureId) continue;
    var pu=num(lData[k][6]||lData[k][5]); var qte=num(lData[k][4])||1;
    var ht=pu*qte*(1-num(lData[k][7])/100)-num(lData[k][8])*qte;
    total+=ht*(1+num(lData[k][9])/100);
  }
  var paye=0;
  for(var m=1;m<pData.length;m++){ if(pData[m][1]===factureId) paye+=num(pData[m][5]); }
  var reste=Math.round((total-paye)*100)/100;
  // Jours de retard
  var echeance=origF[3]; var jours=0;
  if(echeance){ jours=Math.max(0,Math.floor((new Date()-new Date(echeance))/86400000)); }
  // Niveau relance
  var niveau=relanceType|| (jours<8?"rappel":jours<16?"relance":jours<31?"ferme":"litige");
  var niveauTxt=jours<8?"Rappel de paiement":jours<16?"Relance":jours<31?"Relance ferme":"Mise en demeure";
  var cfg={}; try{ var cfgData=sh("Config").getDataRange().getValues(); for(var ci=1;ci<cfgData.length;ci++){ if(cfgData[ci][0]) cfg[cfgData[ci][0]]=cfgData[ci][1]; } }catch(e){}
  var nomClub=cfg.nom||"Tennis & Padel Club Nice";
  var emailClub=cfg.email||ADMIN_EMAIL||Session.getActiveUser().getEmail();
  var nomClient=String(client[1]||"")+" "+String(client[2]||"");
  var emailClient=String(client[4]||"");
  var subject=niveauTxt+" — Facture "+factureId+" — "+nomClub;
  var corps = jours<8
    ? "Bonjour "+nomClient+",\n\nNous vous rappelons que la facture n°"+factureId+" d'un montant de "+reste.toFixed(2)+"€ est due depuis le "+echeance+".\n\nMerci de procéder au règlement.\n\nCordialement,\n"+nomClub
    : jours<16
    ? "Bonjour "+nomClient+",\n\nSans réponse de votre part concernant la facture n°"+factureId+" ("+reste.toFixed(2)+"€), nous vous relançons une seconde fois.\n\nÉchéance dépassée de "+jours+" jours.\n\nMerci de régulariser rapidement.\n\nCordialement,\n"+nomClub
    : jours<31
    ? "Bonjour "+nomClient+",\n\nMalgré nos relances, la facture n°"+factureId+" ("+reste.toFixed(2)+"€) reste impayée depuis "+jours+" jours.\n\nNous vous demandons de régler cette somme sous 48h.\n\nCordialement,\n"+nomClub
    : "Bonjour "+nomClient+",\n\nLa facture n°"+factureId+" ("+reste.toFixed(2)+"€) est impayée depuis "+jours+" jours.\n\nSans règlement sous 5 jours, nous nous verrons contraints d'engager des démarches de recouvrement.\n\nCordialement,\n"+nomClub;
  MailApp.sendEmail({to:emailClient, cc:emailClub, subject:subject, body:corps});
  // Log relance dans Factures
  var notes=origF[5]||"";
  notes+=(notes?"\n":"")+"Relance "+niveauTxt+" envoyée le "+today()+" par "+staffN;
  updateFacture({id:factureId,notes:notes});
  return json({ok:true,niveau:niveau,jours:jours,emailEnvoye:emailClient});
}

function sendEmail(body){
  var clientId=body.clientId; var sujet=body.sujet||"Message du club"; var message=body.message||"";
  if(!clientId||!message) return json({ok:false,error:"clientId et message requis"});
  var cData=sh("Clients").getDataRange().getValues();
  for(var i=1;i<cData.length;i++){
    if(cData[i][0]===clientId){
      var email=String(cData[i][4]||"");
      if(!email) return json({ok:false,error:"Email client manquant"});
      var cfg={}; try{ var cfgData=sh("Config").getDataRange().getValues(); for(var ci=1;ci<cfgData.length;ci++){ if(cfgData[ci][0]) cfg[cfgData[ci][0]]=cfgData[ci][1]; }}catch(e){}
      var emailClub=cfg.email||ADMIN_EMAIL||Session.getActiveUser().getEmail();
      MailApp.sendEmail({to:email, cc:emailClub, subject:sujet, body:message});
      return json({ok:true});
    }
  }
  return json({ok:false,error:"Client non trouvé"});
}

