function ss() {
  if (!SS_ID) throw new Error("SS_ID non configuré — collez l'ID du Google Sheet ligne 3");
  return SpreadsheetApp.openById(SS_ID);
}
function sh(name) {
  var s = ss().getSheetByName(name);
  if (!s) throw new Error("Onglet manquant: " + name);
  return s;
}
function json(obj, code) {
  return ContentService.createTextOutput(JSON.stringify(obj)).setMimeType(ContentService.MimeType.JSON);
}
function now()  { return new Date().toISOString(); }
function today(){ return new Date().toISOString().slice(0,10); }
function heure(){ var d=new Date(); return ("0"+d.getHours()).slice(-2)+":"+("0"+d.getMinutes()).slice(-2); }
function uid(p) { return (p||"id")+"_"+Date.now()+"_"+Math.floor(Math.random()*9999); }
function num(v) { var n=parseFloat(String(v||0).replace(",",".")); return isFinite(n)?n:0; }
function round2(v){ return Math.round(num(v)*100)/100; }
function bool(v){ return v===true||v==="OUI"||v==="true"; }
function parsePercent(v, fallback){
  if(v===null||v===undefined) return fallback;
  var raw=String(v).trim();
  if(raw==="") return fallback;
  var n=parseFloat(raw.replace(",","."));
  if(!isFinite(n)) return fallback;
  return n;
}

function findFactureRow(factureId){
  if(!factureId) return null;
  var fData=sh("Factures").getDataRange().getValues();
  for(var i=1;i<fData.length;i++){
    if(String(fData[i][0]||"").trim()===String(factureId).trim()) return {rowIndex:i+1,row:fData[i]};
  }
  return null;
}
function updateClientSoldeByDelta(clientId, delta, updatedAt){
  if(!clientId || !delta) return null;
  var s=sh("Clients");
  var data=s.getDataRange().getValues();
  for(var i=1;i<data.length;i++){
    if(String(data[i][0]||"").trim()===String(clientId).trim()){
      var newSolde=round2(num(data[i][6])+delta);
      s.getRange(i+1,7).setValue(newSolde);
      s.getRange(i+1,15).setValue(updatedAt||now());
      return newSolde;
    }
  }
  return null;
}
function factureTotalsFromData(factureId, lData, pData){
  var total=0;
  for(var i=1;i<lData.length;i++){
    if(lData[i][1]!==factureId) continue;
    var pu=num(lData[i][6]||lData[i][5]); var qte=num(lData[i][4])||1;
    var ht=pu*qte*(1-num(lData[i][7])/100)-num(lData[i][8])*qte;
    total+=ht*(1+num(lData[i][9])/100);
  }
  var paye=0;
  for(var j=1;j<pData.length;j++){
    if(pData[j][1]===factureId) paye+=num(pData[j][5]);
  }
  total=round2(total); paye=round2(paye);
  return {total:total,paye:paye,reste:round2(total-paye)};
}
function allocationAvoir(montantAvoir, resteFacture){
  var montant=round2(Math.max(0,montantAvoir));
  var reste=round2(Math.max(0,resteFacture));
  var applique=round2(Math.min(montant,reste));
  return {montant:montant,applique:applique,surplus:round2(montant-applique)};
}
function clientExists(clientId){
  if(!clientId) return false;
  var cData=sh("Clients").getDataRange().getValues();
  for(var i=1;i<cData.length;i++){
    if(String(cData[i][0]||"").trim()===String(clientId).trim()) return true;
  }
  return false;
}
function isProduitActif(v){
  if(v===false) return false;
  var raw=String(v===undefined||v===null?"":v).trim().toUpperCase();
  return raw!=="NON" && raw!=="FALSE" && raw!=="0";
}

function lockScript(){
  var lock = LockService.getScriptLock();
  lock.waitLock(30000);
  return lock;
}
function normalizeReqId(requestId){
  return String(requestId||"").trim();
}
function requestLogSheet(){
  var wb=ss();
  var s=wb.getSheetByName("RequestLog");
  if(!s){
    s=wb.insertSheet("RequestLog");
    s.appendRow(["requestId","action","resourceId","createdAt"]);
  }
  return s;
}
function findRequestLog(requestId){
  var rid=normalizeReqId(requestId);
  if(!rid) return null;
  var s=requestLogSheet();
  var data=s.getDataRange().getValues();
  for(var i=1;i<data.length;i++){
    if(String(data[i][0]||"")===rid){
      return {row:i+1, requestId:rid, action:String(data[i][1]||""), resourceId:String(data[i][2]||""), createdAt:data[i][3]};
    }
  }
  return null;
}
function saveRequestLog(requestId, action, resourceId){
  var rid=normalizeReqId(requestId);
  if(!rid) return;
  requestLogSheet().appendRow([rid, action||"", resourceId||"", now()]);
}

