function listFactures(body){
  var shF=sh("Factures"); var shL=sh("Lignes"); var shP=sh("Paiements");
  var fData=shF.getDataRange().getValues();
  var lData=shL.getDataRange().getValues();
  var pData=shP.getDataRange().getValues();
  // Index lignes
  var lMap={};
  for(var i=1;i<lData.length;i++){
    var fid=lData[i][1]; if(!fid) continue;
    if(!lMap[fid]) lMap[fid]=[];
    lMap[fid].push({id:lData[i][0],factureId:fid,desc:lData[i][2],emoji:lData[i][3],
      qte:num(lData[i][4])||1,pu:num(lData[i][5]),prixSaisi:num(lData[i][6]),
      remisePct:num(lData[i][7]),remiseEur:num(lData[i][8]),tva:parsePercent(lData[i][9],20),produitId:lData[i][10]||""});
  }
  // Index paiements
  var pMap={};
  for(var j=1;j<pData.length;j++){
    var pfid=pData[j][1]; if(!pfid) continue;
    if(!pMap[pfid]) pMap[pfid]=[];
    pMap[pfid].push({id:pData[j][0],factureId:pfid,clientId:pData[j][2],
      date:pData[j][3],heure:pData[j][4],montant:num(pData[j][5]),
      mode:pData[j][6],staff:pData[j][7],note:pData[j][8],createdAt:pData[j][9]});
  }
  var res=[];
  for(var k=1;k<fData.length;k++){
    var r=fData[k]; if(!r[0]) continue;
    var f={id:r[0],clientId:r[1],date:r[2],echeance:r[3],statut:r[4],notes:r[5],staff:r[6],
      createdAt:r[7],updatedAt:r[8],fromCaisse:bool(r[9]),
      lignes:lMap[r[0]]||[],paiements:pMap[r[0]]||[]};
    if(body&&body.clientId&&f.clientId!==body.clientId) continue;
    res.push(f);
  }
  return json({ok:true,factures:res});
}
function genFactureId(){
  var data=sh("Factures").getDataRange().getValues();
  var yr=new Date().getFullYear().toString(); var max=0;
  for(var i=1;i<data.length;i++){
    var id=String(data[i][0]||"");
    if(id.indexOf(yr+"-")===0){ var n=parseInt(id.split("-")[1])||0; if(n>max)max=n; }
  }
  return yr+"-"+("0000"+(max+1)).slice(-4);
}
